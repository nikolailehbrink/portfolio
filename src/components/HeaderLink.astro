---
import { cn } from "@/lib/utils";
import type { HTMLAttributes } from "astro/types";
import type { NavigationLink } from "@/data/navigation";

type Props = Omit<HTMLAttributes<"a">, "href"> & NavigationLink;

const { class: className, path, icon: Icon, label, ...props } = Astro.props;

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
const subpath = pathname.match(/[^/]+/g);
const isActive = path === pathname || path === "/" + (subpath?.[0] || "");
---

<a
  href={path}
  class={cn(
    "flex gap-1 rounded-lg border px-3 py-1 active:inset-shadow-xs sm:text-sm",
    isActive
      ? "border-border bg-muted text-foreground"
      : `border-border/75 bg-neutral-50 text-muted-foreground
        hover:border-border hover:bg-muted max-sm:px-2 dark:bg-neutral-900`,
    className,
  )}
  {...props}
  data-astro-prefetch
>
  <Icon className="size-6 sm:size-5" weight="duotone" />
  <span class={!isActive ? "max-sm:sr-only" : ""}>{label}</span>
</a>
