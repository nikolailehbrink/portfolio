---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

type Props = {
  src: ImageMetadata;
  alt: string;
  caption?: string;
};

const { src, alt, caption = alt } = Astro.props;
---

<figure class="not-prose my-8">
  <Image
    src={src}
    alt={alt}
    class="h-auto w-full rounded-lg border border-border"
  />
  <figcaption class="mt-3 text-center text-sm text-muted-foreground">
    {caption}
  </figcaption>
</figure>
