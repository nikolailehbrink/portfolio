---
type Props = {
  mp4: string;
  poster: string;
  caption: string;
};

const { mp4, poster, caption } = Astro.props;
---

<figure class="not-prose my-8">
  <video
    class="h-auto w-full rounded-lg border border-border"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster={poster}
    aria-label={caption}
  >
    <source src={mp4} type="video/mp4" />
  </video>
  <figcaption class="mt-3 text-center text-sm text-muted-foreground">
    {caption}
  </figcaption>
</figure>
